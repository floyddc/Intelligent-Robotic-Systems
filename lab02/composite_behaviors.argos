<?xml version="1.0" ?>
 
<argos-configuration>
 
  <!-- ************************* -->
  <!-- * General configuration * -->
  <!-- ************************* -->
  <framework>
    <system threads="0" />
    <experiment length="0"
                ticks_per_second="10"
     />
  </framework>
 
  <!-- *************** -->
  <!-- * Controllers * -->
  <!-- *************** -->
  <controllers>

    <lua_controller id="lua">
      <actuators>
        <differential_steering implementation="default" noise_level="0.00"/>
      </actuators>
      <sensors>
        <footbot_proximity implementation="default" show_rays="true" noise_level="0.00" />
        <footbot_light implementation="rot_z_only" show_rays="true" noise_level="0.00" />
        <positioning implementation="default" noise_level="0.0" />
        <differential_steering implementation="default" noise_level="0"/>
      </sensors>
     <params script="composite_behaviors.lua" />
    </lua_controller>
    
</controllers>
 

  <!-- *********************** -->
  <!-- * Arena configuration * -->
  <!-- *********************** -->
  <arena size="6, 6, 1" center="0,0,0.5" positional_grid_size="6,6,1">
    <box id="bn" size="0.1, 6, 0.2" movable="false">
      <body position="2.9, 0, 0"  orientation="0,0,0" />
    </box>
    <box id="bs" size="0.1, 6, 0.2" movable="false">
      <body position="-2.9,0,0" orientation="0,0,0" />
    </box>
    <box id="be" size="6, 0.1, 0.2" movable="false">
      <body position="0,-2.9,0" orientation="0,0,0" />
    </box>
    <box id="bw" size="6, 0.1, 0.2" movable="false">
      <body position="0,2.9,0" orientation="0,0,0" />
    </box>
 
    <light id="light"
           position="2.5,0,0.5"
           orientation="0,0,0"
           color="yellow"
           intensity="2"
           medium="leds"/>
    
    <distribute>
      <position method="uniform" min="-2.9,-2.9,0" max="-2,2.9,0" />
      <orientation method="uniform" min="0,0,0" max="360,0,0" />
      <entity quantity="4" max_trials="100">
        <foot-bot id="fb1">
          <controller config="lua" />
        </foot-bot>
      </entity>
    </distribute>

    <!--    <foot-bot id="fb">
      <controller config="lua" />
      <body position="0.2,0.3,0" orientation="0,0,0" />
    </foot-bot>-->

    <!-- OBSTACLES -->
    <distribute>
      <position method="uniform" min="-2.5,-2.5,0" max="1,2.5,0" />
      <orientation method="uniform" min="0,0,0" max="360,0,0" />
      <entity quantity="10" max_trials="100">
        <box id="o1" size="0.2, 0.6, 0.2" movable="false" />
      </entity>
    </distribute>
    
    <distribute>
      <position method="uniform" min="-2.5,-2.5,0" max="1,2.5,0" />
      <orientation method="uniform" min="0,0,0" max="360,0,0" />
      <entity quantity="3" max_trials="100">
        <box id="o2" size="0.2, 1, 0.5" movable="false" />
      </entity>
    </distribute>
    
    <distribute>
      <position method="uniform" min="-2.5,-2.5,0" max="1,2.5,0" />
      <orientation method="uniform" min="0,0,0" max="360,0,0" />
      <entity quantity="2" max_trials="100">
        <box id="o3" size="0.2, 2, 0.2" movable="false" />
      </entity>
    </distribute>
    
  </arena>
 
  <!-- ******************* -->
  <!-- * Physics engines * -->
  <!-- ******************* -->
  <physics_engines>
    <dynamics2d id="dyn2d" />
  </physics_engines>
 
  <!-- ********* -->
  <!-- * Media * -->
  <!-- ********* -->
  <media>
    <led id="leds" />
  </media>

	
  <!-- ****************** -->
  <!-- * Visualization * -->
  <!-- ****************** -->
  <visualization>
    <qt-opengl lua_editor="false">
      <camera>
        <placements>
          <placement index="0" position="7.07336,0.133596,11.0428" look_at="6.54686,0.133596,10.1926" up="-0.850175,-2.16681e-15,0.5265" lens_focal_length="65" />
          <placement index="1" position="1.89752,0.195694,14.7256" look_at="1.77356,0.195694,13.7333" up="-0.992287,-1.91036e-14,0.12396" lens_focal_length="65" />
        </placements>
      </camera>
    </qt-opengl>
  </visualization>

</argos-configuration>
